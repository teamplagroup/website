---
interface Props {
  variant?: "over-hero" | "solid";
}

const { variant = "solid" } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const links = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/industries", label: "Industries" },
  { href: "/contact", label: "Contact" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<nav class:list={["nav", `nav--${variant}`]} aria-label="Primary">
  <div class="nav__inner container">
    <a href="/" class="nav__wordmark" aria-label="The PLA Group, home">
      <span class="nav__wordmark-em">the</span>&nbsp;PLA&nbsp;<span
        class="nav__wordmark-em">group</span>
    </a>

    <button
      class="nav__toggle"
      type="button"
      aria-label="Open menu"
      aria-controls="primary-menu"
      aria-expanded="false"
      data-nav-toggle
    >
      MENU <span class="nav__dot" aria-hidden="true">●</span>
    </button>

    <ul id="primary-menu" class="nav__links" data-nav-menu>
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={["nav__link", isActive(l.href) && "is-active"]}
              aria-current={isActive(l.href) ? "page" : undefined}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const menu = document.querySelector<HTMLUListElement>("[data-nav-menu]");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    });
  }
</script>

<style>
  .nav {
    z-index: 10;
    padding-block: 24px;
    background: transparent;
  }

  .nav--over-hero {
    position: absolute;
    inset: 0 0 auto 0;
  }

  .nav--solid {
    background: var(--pla-navy);
    border-bottom: 1px solid var(--pla-iron);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .nav__wordmark {
    font-family: var(--font-primary);
    font-size: 20px;
    font-weight: 400;
    letter-spacing: -0.03em;
    color: var(--pla-vellum);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav__wordmark-em {
    font-style: italic;
    color: var(--pla-ash);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav__link {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pla-vellum);
    text-decoration: none;
    padding-block: 8px;
    border-bottom: 1px solid transparent;
    transition: color 120ms ease, border-color 120ms ease;
  }

  .nav__link:hover {
    color: var(--pla-gold);
  }

  .nav__link.is-active {
    color: var(--pla-gold);
    border-bottom-color: var(--pla-gold);
  }

  .nav__toggle {
    display: none;
    background: transparent;
    border: 0;
    padding: 8px 0;
    color: var(--pla-vellum);
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    align-items: center;
    gap: 8px;
  }

  .nav__dot {
    color: var(--pla-gold);
    font-size: 10px;
    line-height: 1;
  }

  @media (max-width: 820px) {
    .nav__toggle {
      display: inline-flex;
    }

    .nav__links {
      display: none;
      flex-direction: column;
      align-items: flex-start;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 24px;
      gap: 16px;
      background: var(--pla-navy);
      border-top: 1px solid var(--pla-iron);
      border-bottom: 1px solid var(--pla-iron);
    }

    .nav__links.is-open {
      display: flex;
    }
  }
</style>
