---
import Button from "./Button.astro";
import Nav from "./Nav.astro";

interface Props {
  eyebrow?: string;
  headline: string;
  subhead: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  image?: string;
  compact?: boolean;
}

const {
  eyebrow,
  headline,
  subhead,
  primaryCtaLabel,
  primaryCtaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  // Placeholder hero: architectural up-angle from Unsplash. Swap for a
  // licensed capital-project photograph before launch.
  image = "https://images.unsplash.com/photo-1449157291145-7efd050a4d0e?auto=format&fit=crop&w=2400&q=80",
  compact = false,
} = Astro.props;
---

<header
  class:list={["hero", compact && "hero--compact"]}
  style={`background-image: linear-gradient(180deg, rgba(28,43,74,0.55) 0%, rgba(28,43,74,0.90) 100%), url(${image});`}
>
  <Nav variant="over-hero" />

  <div class="hero__content container">
    {eyebrow && <p class="caption hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__headline">{headline}</h1>
    <p class="hero__subhead">{subhead}</p>
    {
      (primaryCtaLabel || secondaryCtaLabel) && (
        <div class="hero__cta">
          {primaryCtaLabel && primaryCtaHref && (
            <Button href={primaryCtaHref} variant="gold">
              {primaryCtaLabel}
            </Button>
          )}
          {secondaryCtaLabel && secondaryCtaHref && (
            <Button href={secondaryCtaHref} variant="ghost">
              {secondaryCtaLabel}
            </Button>
          )}
        </div>
      )
    }
  </div>
</header>

<style>
  .hero {
    position: relative;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    min-height: min(88vh, 820px);
    padding-top: 100px;
    padding-bottom: 72px;
    background-color: var(--pla-navy);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: flex-end;
    border: 0;
    border-radius: 0;
    border-bottom: 1px solid var(--pla-iron);
  }

  .hero--compact {
    min-height: min(64vh, 560px);
    padding-bottom: 64px;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: var(--container-max);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  .hero__eyebrow {
    color: var(--pla-gold);
    margin-bottom: 8px;
  }

  .hero__headline {
    font-size: var(--fs-display);
    line-height: var(--lh-display);
    letter-spacing: -0.03em;
    max-width: 18ch;
  }

  .hero--compact .hero__headline {
    font-size: 58px;
    line-height: 1.06;
    max-width: 22ch;
  }

  .hero__subhead {
    font-size: var(--fs-subheading);
    line-height: var(--lh-subheading);
    letter-spacing: -0.03em;
    color: var(--pla-vellum);
    max-width: 46ch;
  }

  .hero__cta {
    margin-top: 16px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 620px;
      padding-top: 120px;
      padding-bottom: 56px;
    }

    .hero--compact {
      min-height: 480px;
    }

    .hero--compact .hero__headline {
      font-size: 40px;
    }
  }
</style>
