---
import Button from "./Button.astro";
import Nav from "./Nav.astro";

interface Props {
  eyebrow?: string;
  headline: string;
  subhead: string;
  ctaLabel: string;
  ctaHref: string;
}

const { eyebrow, headline, subhead, ctaLabel, ctaHref } = Astro.props;

// TODO: self-host a licensed aerial/satellite image and replace this URL.
const heroImage =
  "https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?auto=format&fit=crop&w=2400&q=80";
---

<header
  class="hero"
  style={`background-image: linear-gradient(180deg, rgba(28,43,74,0.55) 0%, rgba(28,43,74,0.85) 100%), url(${heroImage});`}
>
  <Nav />

  <div class="hero__content container">
    {eyebrow && <p class="caption hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__headline">{headline}</h1>
    <p class="hero__subhead">{subhead}</p>
    <div class="hero__cta">
      <Button href={ctaHref} variant="gold">{ctaLabel}</Button>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    min-height: min(88vh, 820px);
    padding-top: 100px;
    padding-bottom: 72px;
    background-color: var(--pla-navy);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: flex-end;
    border: 0;
    border-radius: 0;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: var(--container-max);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  .hero__eyebrow {
    color: var(--pla-gold);
    margin-bottom: 8px;
  }

  .hero__headline {
    font-size: var(--fs-display);
    line-height: var(--lh-display);
    letter-spacing: -0.03em;
    max-width: 18ch;
  }

  .hero__subhead {
    font-size: var(--fs-subheading);
    line-height: var(--lh-subheading);
    letter-spacing: -0.03em;
    color: var(--pla-vellum);
    max-width: 42ch;
  }

  .hero__cta {
    margin-top: 16px;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 620px;
      padding-top: 120px;
      padding-bottom: 56px;
    }
  }
</style>
