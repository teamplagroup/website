---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";

// TODO: source and self-host licensed photography for the full-bleed band.
const bandImage =
  "https://images.unsplash.com/photo-1449157291145-7efd050a4d0e?auto=format&fit=crop&w=2400&q=80";

const services = [
  {
    caption: "01",
    title: "Executive Project Advisory",
    body: "Senior-level guidance for complex project decisions, governance challenges, stakeholder alignment, and delivery risk.",
  },
  {
    caption: "02",
    title: "EPC Strategy & Execution",
    body: "Practical support for execution planning, contracting strategy, procurement, interface management, and project controls alignment.",
  },
  {
    caption: "03",
    title: "Project Recovery",
    body: "Experienced leadership support for projects facing cost, schedule, contractual, commercial, or execution challenges.",
  },
  {
    caption: "04",
    title: "Contract & Change Management",
    body: "Commercial and contractual advisory support for claims, change management, owner–contractor alignment, and executive issue framing.",
  },
  {
    caption: "05",
    title: "Commissioning & Startup Readiness",
    body: "Support for construction completion, commissioning, startup, handover, closeout, and early operations readiness.",
  },
];

const experienceBar = [
  "35+ Years Global Experience",
  "Full Lifecycle EPC Execution",
  "Major Energy & Infrastructure Programs",
  "Project Leadership Through Startup & Closeout",
];

const pillars = [
  {
    title: "Executive Judgment",
    body: "Senior-level perspective on high-stakes project decisions, governance challenges, and stakeholder alignment.",
  },
  {
    title: "Delivery Discipline",
    body: "Focus on the fundamentals that determine project success: scope, schedule, cost, risk, quality, safety, and accountability.",
  },
  {
    title: "Commercial Awareness",
    body: "Understanding of the contractual, financial, and commercial realities that shape project outcomes.",
  },
  {
    title: "Global EPC Experience",
    body: "Depth across international project environments, multidisciplinary teams, and complex stakeholder structures.",
  },
];
---

<BaseLayout
  title="The PLA Group | Executive Project Leadership Advisory"
  description="The PLA Group provides executive project leadership and advisory services for complex energy, infrastructure, and capital projects worldwide."
>
  <Hero
    eyebrow="The Project Leadership Advisory Group"
    headline="Executive Project Leadership for Complex Capital Projects"
    subhead="The PLA Group provides strategic advisory and leadership support for owners, operators, EPC contractors, and project teams delivering high-value energy and infrastructure projects worldwide."
    primaryCtaLabel="Schedule a Consultation"
    primaryCtaHref="/contact"
    secondaryCtaLabel="Explore Our Services"
    secondaryCtaHref="/services"
  />

  <!-- Experience Bar --------------------------------------------------- -->
  <section class="section experience" aria-label="Experience">
    <div class="container">
      <ul class="experience__list">
        {
          experienceBar.map((item) => (
            <li class="experience__item">
              <span class="experience__dot" aria-hidden="true">●</span>
              <span class="experience__text">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <hr class="hairline container-hairline" />

  <!-- Stakes ----------------------------------------------------------- -->
  <section class="section" id="stakes">
    <div class="container">
      <p class="caption section__eyebrow">What we do</p>
      <h2 class="section__title">Project Leadership When the Stakes Are High</h2>
      <div class="stakes__body">
        <p>
          Major capital projects carry major consequences. Cost, schedule,
          safety, quality, contracts, stakeholders, and execution decisions
          all have to move together.
        </p>
        <p>
          The PLA Group helps leadership teams strengthen project execution,
          improve governance, manage risk, and make better decisions at
          critical moments.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Do — 5 cards --------------------------------------------- -->
  <section class="section" id="what-we-do">
    <div class="container">
      <p class="caption section__eyebrow">Practice areas</p>
      <h2 class="section__title">Five disciplines. One standard.</h2>

      <ul class="cards">
        {
          services.map((s) => (
            <li class="card">
              <p class="caption card__caption">{s.caption}</p>
              <h3 class="card__title">{s.title}</h3>
              <p class="card__body">{s.body}</p>
            </li>
          ))
        }
      </ul>

      <div class="section__foot">
        <Button href="/services" variant="ghost">
          See all services
        </Button>
      </div>
    </div>
  </section>

  <!-- Full-bleed band -------------------------------------------------- -->
  <section
    class="band"
    aria-hidden="true"
    style={`background-image: linear-gradient(180deg, rgba(28,43,74,0.35) 0%, rgba(28,43,74,0.65) 100%), url(${bandImage});`}
  >
  </section>

  <!-- Why The PLA Group ----------------------------------------------- -->
  <section class="section" id="why">
    <div class="container">
      <p class="caption section__eyebrow">Why The PLA Group</p>
      <h2 class="section__title">Experience That Goes Beyond Advice</h2>
      <div class="why__lede">
        <p>
          The PLA Group brings decades of real-world project leadership
          experience across complex EPC environments. We understand the
          realities of delivering major projects because we have led them.
        </p>
        <p>
          Our work helps clients bring clarity, discipline, and experienced
          judgment to the projects that matter most.
        </p>
      </div>

      <ul class="pillars">
        {
          pillars.map((p) => (
            <li class="pillar">
              <h3 class="pillar__title">{p.title}</h3>
              <p class="pillar__body">{p.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <hr class="hairline container-hairline" />

  <!-- Founder --------------------------------------------------------- -->
  <section class="section" id="founder">
    <div class="container founder">
      <div class="founder__eyebrow">
        <p class="caption section__eyebrow">Founder</p>
        <h2 class="section__title">Led by Luis Hernandez</h2>
      </div>

      <div class="founder__body">
        <p>
          Luis Hernandez is a senior EPC and project leadership executive with
          more than 35 years of global experience delivering large, complex
          energy and infrastructure programs across the Americas, Europe, the
          Middle East, and Asia.
        </p>
        <p>
          His experience spans full lifecycle EPC execution, contract
          administration, change management, commercial strategy, risk
          mitigation, safety leadership, executive reporting, commissioning,
          startup, and project closeout.
        </p>
        <p>
          Through The PLA Group, Luis helps clients strengthen execution,
          improve governance, and bring experienced leadership to high-stakes
          capital projects.
        </p>
        <div class="founder__cta">
          <Button href="/about" variant="ghost">
            More about Luis
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -------------------------------------------------------- -->
  <section class="section cta-band">
    <div class="container cta">
      <p class="caption section__eyebrow">Get in touch</p>
      <h2 class="section__title">
        Bring Executive-Level Leadership to Your Project
      </h2>
      <p class="cta__body">
        If your organization is planning, executing, recovering, or closing
        out a complex capital project, The PLA Group can help.
      </p>
      <div class="cta__actions">
        <Button href="/contact" variant="gold">Start the Conversation</Button>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .section__eyebrow {
    color: var(--pla-gold);
    margin-bottom: 20px;
  }

  .section__title {
    font-size: var(--fs-heading);
    line-height: var(--lh-heading);
    letter-spacing: -0.03em;
    max-width: 26ch;
    margin-bottom: 56px;
  }

  .section__foot {
    margin-top: 56px;
  }

  .container-hairline {
    width: min(100% - 48px, var(--container-max));
    margin-inline: auto;
  }

  /* --- Experience bar ------------------------------------------------- */

  .experience {
    padding-block: 40px;
  }

  .experience__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 32px;
  }

  .experience__item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.4;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--pla-vellum);
  }

  .experience__dot {
    color: var(--pla-gold);
    font-size: 10px;
    line-height: 1.4;
  }

  @media (max-width: 900px) {
    .experience__list {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  /* --- Stakes --------------------------------------------------------- */

  .stakes__body {
    max-width: 58ch;
    display: flex;
    flex-direction: column;
    gap: var(--paragraph-gap);
    font-size: 22px;
    line-height: 1.55;
  }

  /* --- Cards ---------------------------------------------------------- */

  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px;
  }

  .cards .card:nth-child(4),
  .cards .card:nth-child(5) {
    grid-column: span 1;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px 0 0 0;
    border-top: 1px solid var(--pla-iron);
  }

  .card__caption {
    color: var(--pla-gold);
  }

  .card__title {
    font-size: var(--fs-subheading);
    line-height: var(--lh-subheading);
    letter-spacing: -0.03em;
    max-width: 20ch;
  }

  .card__body {
    color: var(--pla-vellum);
  }

  @media (max-width: 1000px) {
    .cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }

  /* --- Band ----------------------------------------------------------- */

  .band {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    height: min(56vh, 520px);
    background-color: var(--pla-navy);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border: 0;
    border-radius: 0;
  }

  /* --- Why ------------------------------------------------------------ */

  .why__lede {
    max-width: 58ch;
    display: flex;
    flex-direction: column;
    gap: var(--paragraph-gap);
    margin-bottom: 96px;
    font-size: 22px;
    line-height: 1.55;
  }

  .pillars {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 40px;
  }

  .pillar {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 24px;
    border-top: 1px solid var(--pla-iron);
  }

  .pillar__title {
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  @media (max-width: 1000px) {
    .pillars {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .pillars {
      grid-template-columns: 1fr;
    }
  }

  /* --- Founder -------------------------------------------------------- */

  .founder {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 64px;
    align-items: start;
  }

  .founder__eyebrow .section__title {
    margin-bottom: 0;
  }

  .founder__body {
    max-width: 62ch;
    display: flex;
    flex-direction: column;
    gap: var(--paragraph-gap);
  }

  .founder__cta {
    margin-top: 16px;
  }

  @media (max-width: 900px) {
    .founder {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* --- Final CTA ------------------------------------------------------ */

  .cta-band {
    background: transparent;
  }

  .cta__body {
    max-width: 62ch;
    margin-bottom: 32px;
  }

  .cta__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
</style>
