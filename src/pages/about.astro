---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";

const credibility = [
  "35+ years of global project leadership experience",
  "Full lifecycle EPC execution experience",
  "Leadership on major energy and infrastructure programs",
  "Experience across the Americas, Europe, the Middle East, and Asia",
  "Project leadership across pipelines, subsea, FPSO, gas, offshore, and infrastructure projects",
  "Expertise in contracts, claims, change management, risk, safety, schedule, cost, and project governance",
  "Senior client interface and multidisciplinary team leadership experience",
  "Commissioning, startup, closeout, and operational handover experience",
];

// TODO: replace with licensed photograph of Luis or a suitable executive portrait.
const bandImage =
  "https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=2400&q=80";
---

<BaseLayout
  title="About | The PLA Group"
  description="The PLA Group was founded to bring seasoned executive project leadership to organizations delivering complex, high-value energy and infrastructure projects."
>
  <Hero
    eyebrow="About"
    headline="Built on Decades of Global Project Leadership"
    subhead="The PLA Group was founded to bring seasoned executive project leadership to organizations delivering complex, high-value energy and infrastructure projects."
    compact
  />

  <!-- About the firm --------------------------------------------------- -->
  <section class="section" id="firm">
    <div class="container">
      <p class="caption section__eyebrow">The firm</p>
      <h2 class="section__title">About The PLA Group</h2>
      <div class="prose">
        <p>
          Project Leadership Advisory for owners, operators, EPC contractors,
          joint ventures, and leadership teams delivering complex capital
          projects.
        </p>
        <p>
          Grounded in real project leadership across the full EPC lifecycle:
          strategy, definition, execution, construction, commissioning,
          startup, handover, closeout.
        </p>
      </div>
    </div>
  </section>

  <hr class="hairline container-hairline" />

  <!-- Founder : short bio ----------------------------------------------- -->
  <section class="section" id="founder-short">
    <div class="container founder">
      <div class="founder__eyebrow">
        <p class="caption section__eyebrow">Founder</p>
        <h2 class="section__title">Luis Hernandez</h2>
      </div>

      <div class="founder__body">
        <p>
          Luis Hernandez is a senior EPC executive with 35+ years leading
          major energy and infrastructure programs across the Americas,
          Europe, the Middle East, and Asia.
        </p>
        <p>
          He has led multidisciplinary teams, served as senior client
          interface, and overseen contract administration, change management,
          commercial strategy, risk, safety, commissioning, startup, and
          closeout.
        </p>
      </div>
    </div>
  </section>

  <!-- Full-bleed band -------------------------------------------------- -->
  <section
    class="band"
    aria-hidden="true"
    style={`background-image: linear-gradient(180deg, rgba(28,43,74,0.45) 0%, rgba(28,43,74,0.75) 100%), url(${bandImage});`}
  >
  </section>

  <!-- Founder : long bio ------------------------------------------------ -->
  <section class="section" id="founder-long">
    <div class="container">
      <p class="caption section__eyebrow">Career</p>
      <h2 class="section__title">A Career Built on Project Delivery</h2>

      <div class="prose">
        <p>
          Luis has held senior project leadership roles on major energy and
          infrastructure projects worldwide, including pipeline, subsea, offshore,
          FPSO, gas, and large-scale development. His work spans the full
          project lifecycle from appraisal and concept selection through
          startup, handover, and closeout.
        </p>
        <p>
          Regions include the United States, Canada, Mexico, Trinidad and
          Tobago, Algeria, Norway, India, South Korea, and other global
          project environments.
        </p>
        <p>
          Program and portfolio leadership. Full P&amp;L accountability.
          Commercial strategy, contract administration, claims and change
          management, risk, HSSE, and executive reporting.
        </p>
      </div>

      <!-- Credibility bullets -->
      <div class="credibility">
        <p class="caption credibility__label">Credentials</p>
        <ul class="credibility__list">
          {credibility.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <hr class="hairline container-hairline" />

  <!-- CTA -------------------------------------------------------------- -->
  <section class="section">
    <div class="container">
      <p class="caption section__eyebrow">Get in touch</p>
      <h2 class="section__title">
        Bring Executive-Level Leadership to Your Project
      </h2>
      <p class="cta-copy">
        Tell us about the project. We will respond within one business day.
      </p>
      <Button href="/contact" variant="gold">Start the Conversation</Button>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .section__eyebrow {
    color: var(--pla-gold);
    margin-bottom: 20px;
  }

  .section__title {
    font-size: var(--fs-heading);
    line-height: var(--lh-heading);
    letter-spacing: -0.03em;
    max-width: 26ch;
    margin-bottom: 40px;
  }

  .container-hairline {
    width: min(100% - 48px, var(--container-max));
    margin-inline: auto;
  }

  .prose {
    max-width: 62ch;
    display: flex;
    flex-direction: column;
    gap: var(--paragraph-gap);
  }

  .founder {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 64px;
    align-items: start;
  }

  .founder__eyebrow .section__title {
    margin-bottom: 0;
  }

  .founder__body {
    max-width: 62ch;
    display: flex;
    flex-direction: column;
    gap: var(--paragraph-gap);
  }

  .band {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    height: min(48vh, 440px);
    background-color: var(--pla-navy);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .credibility {
    margin-top: 56px;
  }

  .credibility__label {
    margin-bottom: 20px;
  }

  .credibility__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px 40px;
    max-width: 100%;
  }

  .credibility__list li {
    position: relative;
    padding-left: 20px;
    font-size: var(--fs-body);
    line-height: 1.5;
  }

  .credibility__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 10px;
    height: 1px;
    background: var(--pla-gold);
  }

  .cta-copy {
    max-width: 62ch;
    margin-bottom: 32px;
  }

  @media (max-width: 900px) {
    .founder {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .credibility__list {
      grid-template-columns: 1fr;
    }
  }
</style>
