---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";

const services = [
  {
    number: "01",
    title: "Executive Project Advisory",
    body: [
      "We provide senior-level project advisory support for organizations navigating complex execution challenges, major decisions, stakeholder alignment issues, or critical delivery risks.",
      "Our role is to bring experienced, independent judgment to help leadership teams assess project health, improve decision-making, and move forward with confidence.",
    ],
    includes: [
      "Executive project reviews",
      "Strategic project guidance",
      "Leadership team advisory",
      "Project governance support",
      "Decision-point preparation",
      "Stakeholder communication support",
      "Executive reporting guidance",
    ],
  },
  {
    number: "02",
    title: "EPC Strategy & Execution Support",
    body: [
      "Successful project delivery depends on disciplined execution strategy, clear accountability, and alignment between engineering, procurement, construction, contracts, and operations.",
      "The PLA Group helps project teams evaluate execution plans, identify gaps, strengthen coordination, and improve the practical path to delivery.",
    ],
    includes: [
      "EPC execution strategy",
      "Project planning review",
      "Contracting strategy",
      "Procurement and subcontract strategy",
      "Execution readiness assessment",
      "Interface management",
      "Project controls alignment",
    ],
  },
  {
    number: "03",
    title: "Project Governance & Assurance",
    body: [
      "Complex projects require clear governance, reliable reporting, disciplined risk management, and strong executive visibility.",
      "We help organizations assess project performance, improve governance structures, and establish practical mechanisms for tracking progress, escalating issues, and protecting business outcomes.",
    ],
    includes: [
      "Governance model review",
      "Project assurance reviews",
      "Stage gate support",
      "Risk review and mitigation planning",
      "Executive reporting structure",
      "Cost, schedule, and quality review",
      "Performance monitoring recommendations",
    ],
  },
  {
    number: "04",
    title: "Project Recovery & Turnaround Support",
    body: [
      "When a project is off track, experienced leadership can make the difference between continued drift and disciplined recovery.",
      "The PLA Group helps organizations diagnose root causes, prioritize corrective action, realign stakeholders, and create practical recovery plans for projects facing cost, schedule, contractual, or execution challenges.",
    ],
    includes: [
      "Project health assessment",
      "Recovery planning",
      "Schedule recovery strategy",
      "Commercial and contractual issue review",
      "Stakeholder alignment",
      "Risk prioritization",
      "Execution stabilization",
    ],
  },
  {
    number: "05",
    title: "Contract, Claims & Change Management",
    body: [
      "Major projects are shaped by contracts, commercial strategy, claims, change orders, and the ability to manage obligations clearly and proactively.",
      "The PLA Group supports leadership teams in understanding commercial exposure, improving contract administration, managing change, and preparing for difficult conversations with clients, owners, partners, or contractors.",
    ],
    includes: [
      "Contract administration review",
      "Claims and change strategy",
      "Commercial risk assessment",
      "Owner / contractor interface support",
      "Negotiation preparation",
      "Contract compliance support",
      "Executive-level issue framing",
    ],
  },
  {
    number: "06",
    title: "Construction, Commissioning & Startup Readiness",
    body: [
      "The transition from construction to commissioning, startup, handover, and early operations is one of the most critical phases of any major capital project.",
      "We help teams evaluate readiness, identify execution gaps, improve turnover planning, and support a disciplined path from mechanical completion to operational performance.",
    ],
    includes: [
      "Construction execution review",
      "Commissioning readiness",
      "Startup planning support",
      "Turnover and handover planning",
      "Performance testing readiness",
      "Closeout and warranty management",
      "Early operations risk review",
    ],
  },
];
---

<BaseLayout
  title="Services | EPC & Capital Project Advisory | The PLA Group"
  description="Explore The PLA Group's executive advisory services for EPC strategy, project governance, project recovery, contract management, commissioning readiness, and major capital project delivery."
>
  <Hero
    eyebrow="Services"
    headline="Strategic Advisory for Major Project Delivery"
    subhead="The PLA Group supports complex capital projects through executive advisory, project governance, EPC execution strategy, risk management, construction readiness, commissioning support, and project recovery."
    compact
  />

  <!-- Service sections ------------------------------------------------- -->
  {
    services.map((s, i) => (
      <>
        <section class="section service" id={`s-${s.number}`}>
          <div class="container service__inner">
            <div class="service__lede">
              <p class="caption service__num">{s.number}</p>
              <h2 class="service__title">{s.title}</h2>
            </div>
            <div class="service__body">
              {s.body.map((p) => (
                <p>{p}</p>
              ))}
            </div>
            <div class="service__includes">
              <p class="caption service__includes-label">Includes</p>
              <ul>
                {s.includes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </section>
        {i < services.length - 1 && (
          <hr class="hairline container-hairline" />
        )}
      </>
    ))
  }

  <hr class="hairline container-hairline" />

  <!-- CTA -------------------------------------------------------------- -->
  <section class="section">
    <div class="container">
      <p class="caption section__eyebrow">Next</p>
      <h2 class="section__title">Talk through the project.</h2>
      <p class="cta-copy">
        Whether the challenge is strategy, execution, recovery, contracts, or
        startup, we can help you frame the path forward.
      </p>
      <Button href="/contact" variant="gold">Start the Conversation</Button>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .section__eyebrow {
    color: var(--pla-gold);
    margin-bottom: 20px;
  }

  .section__title {
    font-size: var(--fs-heading);
    line-height: var(--lh-heading);
    letter-spacing: -0.03em;
    max-width: 26ch;
    margin-bottom: 32px;
  }

  .container-hairline {
    width: min(100% - 48px, var(--container-max));
    margin-inline: auto;
  }

  .service__inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 56px;
    align-items: start;
  }

  .service__lede {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: sticky;
    top: 32px;
  }

  .service__num {
    color: var(--pla-gold);
  }

  .service__title {
    font-size: 40px;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .service__body {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 62ch;
  }

  .service__includes {
    grid-column: 2 / -1;
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .service__includes ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px 32px;
  }

  .service__includes li {
    position: relative;
    padding-left: 20px;
    font-size: var(--fs-body);
    line-height: 1.5;
  }

  .service__includes li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 10px;
    height: 1px;
    background: var(--pla-gold);
  }

  .cta-copy {
    max-width: 62ch;
    margin-bottom: 32px;
  }

  @media (max-width: 900px) {
    .service__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .service__lede {
      position: static;
    }

    .service__title {
      font-size: 32px;
    }

    .service__includes {
      grid-column: auto;
    }

    .service__includes ul {
      grid-template-columns: 1fr;
    }
  }
</style>
