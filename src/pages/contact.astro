---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";

const projectTypes = [
  "Executive Project Advisory",
  "EPC Strategy & Execution Support",
  "Project Governance & Assurance",
  "Project Recovery",
  "Contract, Claims & Change Management",
  "Construction, Commissioning & Startup Readiness",
  "Other",
];
---

<BaseLayout
  title="Contact | The PLA Group"
  description="Talk with The PLA Group about your capital project. Whether it is in planning, execution, recovery, commissioning, or closeout, we can help bring experienced leadership and strategic clarity to the table."
>
  <Hero
    eyebrow="Contact"
    headline="Let's Talk About Your Project"
    subhead="Planning, execution, recovery, commissioning, or closeout. We can help."
    compact
  />

  <section class="section" id="form">
    <div class="container contact">
      <div class="contact__lede">
        <p class="caption section__eyebrow">Start a conversation</p>
        <h2 class="contact__title">Confidential by default.</h2>
        <p class="contact__body">
          Use the form to share the essentials. We will follow up within one
          business day to schedule a call.
        </p>

        <p class="contact__body contact__mailto">
          Prefer email?
          <a href="mailto:hello@usetheplagroup.com">
            hello@usetheplagroup.com
          </a>
        </p>
      </div>

      <!-- TODO: replace with real endpoint -->
      <form
        class="form"
        action="https://formspree.io/f/REPLACE_ME"
        method="POST"
      >
        <div class="form__row">
          <label class="form__field">
            <span class="form__label">Name</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="form__input"
            />
          </label>
          <label class="form__field">
            <span class="form__label">Company</span>
            <input
              type="text"
              name="company"
              autocomplete="organization"
              class="form__input"
            />
          </label>
        </div>

        <div class="form__row">
          <label class="form__field">
            <span class="form__label">Email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="form__input"
            />
          </label>
          <label class="form__field">
            <span class="form__label">Phone</span>
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              class="form__input"
            />
          </label>
        </div>

        <label class="form__field">
          <span class="form__label">Project Type</span>
          <select name="project_type" class="form__input form__select">
            <option value="">Select…</option>
            {projectTypes.map((t) => <option value={t}>{t}</option>)}
          </select>
        </label>

        <label class="form__field">
          <span class="form__label">How can we help?</span>
          <textarea
            name="message"
            rows="6"
            required
            class="form__input form__textarea"
          ></textarea>
        </label>

        <button type="submit" class="form__submit">
          Start the Conversation
        </button>

        <p class="form__note">
          We treat every enquiry in confidence. The form is a starting point,
          not a commitment.
        </p>
      </form>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .section__eyebrow {
    color: var(--pla-gold);
    margin-bottom: 20px;
  }

  .contact {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 72px;
    align-items: start;
  }

  .contact__lede {
    position: sticky;
    top: 32px;
  }

  .contact__title {
    font-size: 40px;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
  }

  .contact__body {
    max-width: 42ch;
    margin-bottom: 16px;
  }

  .contact__mailto {
    margin-top: 24px;
    color: var(--pla-vellum);
  }

  .contact__mailto a {
    color: var(--pla-gold);
    text-decoration: none;
    border-bottom: 1px solid var(--pla-gold);
  }

  .contact__mailto a:hover {
    color: var(--pla-vellum);
    border-bottom-color: var(--pla-vellum);
  }

  /* --- Form ----------------------------------------------------------- */

  .form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .form__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form__label {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--pla-ash);
  }

  .form__input {
    background: transparent;
    color: var(--pla-vellum);
    border: 1px solid var(--pla-iron);
    border-radius: 3.6px;
    padding: 14px 16px;
    font-family: var(--font-primary);
    font-size: var(--fs-body);
    letter-spacing: -0.03em;
    transition: border-color 120ms ease;
  }

  .form__input:focus {
    outline: none;
    border-color: var(--pla-gold);
  }

  .form__select {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, var(--pla-gold) 50%),
      linear-gradient(135deg, var(--pla-gold) 50%, transparent 50%);
    background-position: calc(100% - 22px) 50%, calc(100% - 16px) 50%;
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 44px;
  }

  .form__select option {
    color: var(--pla-navy);
  }

  .form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form__submit {
    align-self: flex-start;
    background: var(--pla-gold);
    color: var(--pla-navy);
    border: 0;
    border-radius: 3.6px;
    padding: 14px 22px;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 120ms ease, color 120ms ease;
    margin-top: 8px;
  }

  .form__submit:hover {
    background: var(--pla-gold-deep);
    color: var(--pla-vellum);
  }

  .form__note {
    color: var(--pla-ash);
    font-size: 14px;
    line-height: 1.5;
    max-width: 48ch;
  }

  @media (max-width: 900px) {
    .contact {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .contact__lede {
      position: static;
    }

    .form__row {
      grid-template-columns: 1fr;
    }
  }
</style>
